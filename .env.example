PORT=8787
LEADS_DB_PATH=./data/leads.db
LEAD_WORKER_INTERVAL_MS=7000
LEAD_DELIVERY_MAX_ATTEMPTS=5
LEAD_PROCESSING_STALE_MS=300000
# LEAD_IDEMPOTENCY_BUCKET_MINUTES=10

# Optional: trust reverse-proxy headers (enable in production behind LB/proxy)
# TRUST_PROXY=true

# CORS allowlist for /api (comma-separated origins)
# Dev fallback allows localhost/127.0.0.1 origins when empty.
# Example:
# CORS_ALLOWLIST=https://example.com,https://www.example.com

# Captcha verification (Turnstile / reCAPTCHA / hCaptcha)
# CAPTCHA_PROVIDER=turnstile
# CAPTCHA_VERIFY_URL= (optional override; auto-derived from provider)
# CAPTCHA_SECRET=
# CAPTCHA_TOKEN_FIELD=captcha_token
# CAPTCHA_FAIL_OPEN=false
# CAPTCHA_REQUIRED_IN_PROD=true
# CAPTCHA_MIN_SCORE=0.5
